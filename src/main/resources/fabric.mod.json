{
  "schemaVersion": 1,
  "id": "lunanpc_examples",
  "version": "${version}",
  "name": "LunaNPC Examples",
  "description": "Three self-contained examples of the LunaNPC developer API: a village steel golem, a cave charger zombie, and an advanced-combat nether blaze.",
  "contact": {
    "homepage": "https://lunacore.dev",
    "sources": "https://github.com/raeydzone/lunanpc-examples"
  },
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.lunacore.lunanpc.examples.LunaExamplesMod"
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "luna_npc": "*"
  }
}
